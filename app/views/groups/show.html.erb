<%# Group Detail Page — Tabbed layout %>
<% content_for :title, "#{@group.name} — Splitwise" %>

<% content_for :top_bar do %>
  <%= render "shared/top_bar", title: @group.name, back_path: groups_path %>
<% end %>

<div class="animate-fade-in">

  <%# Group Hero Card %>
  <div class="group-hero">
    <div class="group-hero__avatar group-hero__avatar--<%= @group.group_type %>">
      <% if @group.avatar.attached? %>
        <%= image_tag @group.avatar, class: "group-hero__avatar-img" %>
      <% else %>
        <%= @group.name.first(2).upcase %>
      <% end %>
    </div>
    <div class="group-hero__info">
      <h1 class="group-hero__name"><%= @group.name %></h1>
      <span class="badge badge--<%= @group.group_type %>">
        <%= @group.group_type.capitalize %>
      </span>
      <span class="group-hero__members text-muted">
        &nbsp;· <%= pluralize(@members.count, "member") %>
      </span>
    </div>
    <% if @group.admin?(current_user) %>
      <%= link_to edit_group_path(@group), class: "btn btn--outline btn--sm" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Edit
      <% end %>
    <% end %>
  </div>

  <%# ── MY BALANCE SUMMARY CARD ──────────────────────────── %>
  <div class="grp-balance-card mb-md
    <%= @my_balance_cents > 0 ? 'grp-balance-card--positive' : (@my_balance_cents < 0 ? 'grp-balance-card--negative' : 'grp-balance-card--neutral') %>">

    <%# Total row %>
    <div class="grp-balance-card__total">
      <div class="grp-balance-card__label">
        <% if @my_balance_cents > 0 %>
          You are owed in this group
        <% elsif @my_balance_cents < 0 %>
          You owe in this group
        <% else %>
          You are all settled up
        <% end %>
      </div>
      <div class="grp-balance-card__amount">
        <% if @my_balance_cents == 0 %>
          <span>🎉 &nbsp;PKR 0</span>
        <% else %>
          <%= number_to_currency(@my_balance_cents.abs / 100.0, unit: (current_user.default_currency.presence || "PKR") + " ", precision: 0) %>
        <% end %>
      </div>
    </div>

    <%# Per-member breakdown %>
    <% if @my_balance_detail.any? %>
      <div class="grp-balance-card__divider"></div>
      <% @my_balance_detail.each do |entry| %>
        <div class="grp-balance-card__row">
          <div class="avatar avatar--xs avatar--teal"><%= entry[:user].username.first.upcase %></div>
          <div class="grp-balance-card__row-name"><%= entry[:user].username %></div>
          <% if entry[:net_cents] > 0 %>
            <div class="grp-balance-card__row-amount grp-balance-card__row-amount--owes-you">
              owes you <%= number_to_currency(entry[:net_cents] / 100.0, unit: (current_user.default_currency.presence || "PKR") + " ", precision: 0) %>
            </div>
          <% else %>
            <div class="grp-balance-card__row-amount grp-balance-card__row-amount--you-owe">
              you owe <%= number_to_currency(entry[:net_cents].abs / 100.0, unit: (current_user.default_currency.presence || "PKR") + " ", precision: 0) %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Quick Action Buttons %>
  <div class="d-flex gap-sm mb-lg">
    <%= link_to new_group_expense_path(@group), class: "btn btn--primary flex-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Add Expense
    <% end %>
    <%= link_to new_group_settlement_path(@group), class: "btn btn--outline flex-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;">
        <rect x="2" y="5" width="20" height="14" rx="2"/>
        <line x1="2" y1="10" x2="22" y2="10"/>
      </svg>
      Settle Up
    <% end %>
    <%= link_to new_group_invitation_path(@group), class: "btn btn--ghost flex-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="8.5" cy="7" r="4"/>
        <line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
      </svg>
      Invite
    <% end %>
  </div>

  <%# Tabs %>
  <div class="tabs" id="group-tabs">
    <button class="tab tab--active" data-tab="expenses" onclick="switchTab('expenses')">Expenses</button>
    <button class="tab" data-tab="balances" onclick="switchTab('balances')">Balances</button>
    <button class="tab" data-tab="members" onclick="switchTab('members')">Members</button>
  </div>

  <%# Tab: Expenses %>
  <div id="tab-expenses" class="tab-panel tab-panel--active">
    <% if @expenses.any? %>
      <div class="card card--shadow">
        <% @expenses.each do |expense| %>
          <%= link_to group_expense_path(@group, expense), class: "list-item" do %>
            <div class="category-icon category-icon--<%= expense.category %>">
              <%= { general: "🧾", food: "🍕", transport: "🚗", entertainment: "🎮",
                    utilities: "💡", rent: "🏠", shopping: "🛍️",
                    healthcare: "💊", other: "📦" }[expense.category.to_sym] %>
            </div>
            <div class="list-item__body">
              <div class="list-item__title"><%= expense.title %></div>
              <div class="list-item__subtitle">
                <% if expense.paid_by.present? %>
                  <strong><%= expense.paid_by == current_user ? "You" : expense.paid_by.username %></strong> paid
                <% end %>
                · <%= expense.expense_date.strftime("%b %d") %>
              </div>
            </div>
            <div class="list-item__meta">
              <%# Show my share on this expense %>
              <% my_split = expense.expense_splits.find { |s| s.user_id == current_user.id } %>
              <div class="list-item__amount amount--neutral">
                <%= number_to_currency(expense.total_amount_cents / 100.0,
                      unit: expense.currency + " ", precision: 0) %>
              </div>
              <% if my_split %>
                <% if expense.paid_by_id == current_user.id %>
                  <div class="text-xs" style="color: var(--color-positive);">you paid</div>
                <% elsif my_split.owed_amount_cents > 0 %>
                  <div class="text-xs" style="color: var(--color-negative);">
                    you owe <%= number_to_currency(my_split.owed_amount_cents / 100.0, unit: expense.currency + " ", precision: 0) %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state empty-state--sm">
        <div class="empty-state__icon">🧾</div>
        <p class="empty-state__body">No expenses yet in this group.</p>
        <%= link_to "Add first expense", new_group_expense_path(@group), class: "btn btn--primary btn--sm" %>
      </div>
    <% end %>
  </div>

  <%# Tab: Balances %>
  <div id="tab-balances" class="tab-panel" style="display:none;">
    <% if @balances.any? %>
      <div class="card card--shadow">
        <% @balances.each do |entry| %>
          <div class="list-item">
            <div class="avatar avatar--sm avatar--teal">
              <%= entry[:user].username.first.upcase %>
            </div>
            <div class="list-item__body">
              <div class="list-item__title">
                <%= entry[:user] == current_user ? "You" : entry[:user].username %>
              </div>
              <% if entry[:user] == current_user %>
                <div class="list-item__subtitle text-muted">Your balance</div>
              <% end %>
            </div>
            <div class="list-item__meta">
              <% balance = entry[:balance_cents] %>
              <% is_me = entry[:user] == current_user %>
              <% if balance > 0 %>
                <div class="list-item__amount amount--positive">
                  <%= is_me ? "get back" : "gets back" %> <%= number_to_currency(balance / 100.0,
                        unit: (current_user.default_currency.presence || "PKR") + " ", precision: 0) %>
                </div>
              <% elsif balance < 0 %>
                <div class="list-item__amount amount--negative">
                  <%= is_me ? "owe" : "owes" %> <%= number_to_currency(balance.abs / 100.0,
                        unit: (current_user.default_currency.presence || "PKR") + " ", precision: 0) %>
                </div>
              <% else %>
                <div class="list-item__amount amount--neutral">settled up</div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state empty-state--sm">
        <p class="empty-state__body">Everyone is settled up! 🎉</p>
      </div>
    <% end %>
  </div>

  <%# Tab: Members %>
  <div id="tab-members" class="tab-panel" style="display:none;">
    <% if @pending_invitations.any? %>
      <div class="card card--shadow mb-md">
        <div class="p-md" style="border-bottom: 1px solid var(--border-subtle);">
          <div class="fw-bold">Pending invites</div>
          <div class="text-muted text-sm">Copy a link and send it manually until email is enabled.</div>
        </div>
        <% @pending_invitations.each do |invitation| %>
          <div class="list-item">
            <div class="list-item__body">
              <div class="list-item__title"><%= invitation.email %></div>
              <div class="list-item__subtitle text-muted">Expires <%= invitation.expires_at.strftime("%b %d, %Y") %></div>
            </div>
            <div class="list-item__meta">
              <%= link_to "Copy link",
                    accept_invitation_url(token: invitation.token),
                    class: "btn btn--outline btn--sm",
                    onclick: "navigator.clipboard.writeText(this.href); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy link', 2000); return false;" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="card card--shadow">
      <% @members.each do |gm| %>
        <div class="list-item">
          <div class="avatar avatar--sm avatar--teal">
            <%= gm.user.username.first.upcase %>
          </div>
          <div class="list-item__body">
            <div class="list-item__title"><%= gm.user.username %></div>
            <div class="list-item__subtitle"><%= gm.user.email %></div>
          </div>
          <div class="list-item__meta d-flex align-center gap-sm">
            <% if gm.admin? %>
              <span class="badge badge--admin">Admin</span>
            <% end %>
            <% if @group.admin?(current_user) && gm.user != current_user %>
              <%= button_to group_group_member_path(@group, gm),
                    method: :delete,
                    form: { data: { turbo_confirm: "Remove #{gm.user.username} from this group?" } },
                    class: "btn-icon btn-icon--danger" do %>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14H6L5 6"/>
                  <path d="M10 11v6"/><path d="M14 11v6"/>
                </svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="spacer--lg"></div>
</div>

<script>
  function switchTab(name) {
    document.querySelectorAll(".tab-panel").forEach(function(p) { p.style.display = "none"; });
    document.querySelectorAll(".tab").forEach(function(t) { t.classList.remove("tab--active"); });
    document.getElementById("tab-" + name).style.display = "block";
    document.querySelector('[data-tab="' + name + '"]').classList.add("tab--active");
  }
</script>
