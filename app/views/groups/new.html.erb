<%# New Group Page %>
<% content_for :title, "New Group — Splitwise" %>

<% content_for :top_bar do %>
  <%= render "shared/top_bar", title: "Create Group", back_path: groups_path %>
<% end %>

<div class="animate-fade-in">

  <div class="auth-card" style="max-width: 560px; margin: 0 auto;">
    <h2 class="auth-card__title">New Group</h2>
    <p class="auth-card__subtitle">Give your group a name and pick a type</p>

    <% content_for :submit_label, "Create Group" %>
    <%= render "form", group: @group %>
  </div>

  <div class="spacer--lg"></div>
</div>
