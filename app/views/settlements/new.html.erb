<% content_for :title, "Settle up — #{@group.name}" %>

<% content_for :top_bar do %>
  <header class="ef-top-bar" style="background: var(--color-positive);">
    <%= link_to group_path(@group), class: "ef-top-bar__close", style: "color: white;" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    <% end %>
    <h1 class="ef-top-bar__title" style="color: white;">Settle up</h1>
    <label for="settlement-submit" class="ef-top-bar__save" style="color: white; cursor: pointer;">Save</label>
  </header>
<% end %>

<div class="animate-fade-in ef-page-wrap">
  
  <% if @members.empty? %>
    <div class="card p-lg text-center mt-xl">
      <div class="text-xl mb-sm">🎉</div>
      <h3 class="fw-bold mb-xs">No one to settle up with!</h3>
      <p class="text-muted text-sm">There are no other members in this group yet.</p>
    </div>
  <% else %>

    <%= form_with url: group_settlements_path(@group), local: true, class: "expense-form mt-md" do |f| %>
      
      <div class="card card--shadow p-md mb-md text-center">
        <div class="d-flex align-center justify-center gap-md mb-lg mt-sm">
          <div class="text-center">
            <div class="avatar avatar--lg avatar--teal mx-auto mb-xs"><%= current_user.username.first.upcase %></div>
            <div class="fw-bold text-sm">You</div>
          </div>
          
          <div class="text-muted" style="margin-top: -16px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>

          <div class="text-center">
            <div class="avatar avatar--lg mx-auto mb-xs" style="background: var(--bg-surface-2); border: 2px dashed var(--border-color); color: var(--text-muted);" id="receiver-avatar">?</div>
            <div class="fw-bold text-sm" id="receiver-name">Choose recipient</div>
          </div>
        </div>

        <div class="form-group text-left">
          <%= f.label :receiver_id, "Who are you paying?", class: "form-label" %>
          <%= f.collection_select :receiver_id, @members, :id, :username, { prompt: "Select someone..." }, { class: "form-control", id: "receiver-select", required: true } %>
        </div>

        <div class="d-flex justify-center mt-xl mb-md">
          <div class="ef-field-row" style="border:none; margin:0;">
            <div class="ef-field-icon ef-field-icon--currency" style="background: var(--bg-surface);">
              <%= current_user.default_currency.presence || "PKR" %>
            </div>
            <input type="number" name="amount" class="ef-input ef-input--amount text-center" style="width: 150px; font-weight: 500; color: var(--color-positive);" placeholder="0.00" step="0.01" min="0.01" required>
            <%= f.hidden_field :currency, value: current_user.default_currency %>
          </div>
        </div>
      </div>

      <div class="ef-save-bar">
        <%= f.submit "Save", class: "btn btn--primary btn--block btn--lg", id: "settlement-submit" %>
      </div>
    <% end %>

    <script>
      document.addEventListener("DOMContentLoaded", function() {
        const select = document.getElementById("receiver-select");
        const avatar = document.getElementById("receiver-avatar");
        const name = document.getElementById("receiver-name");

        if (select) {
          select.addEventListener("change", function() {
            if (this.value) {
              const username = this.options[this.selectedIndex].text;
              name.textContent = username;
              avatar.textContent = username.charAt(0).toUpperCase();
              avatar.style.background = "var(--color-primary)";
              avatar.style.color = "white";
              avatar.style.border = "none";
            } else {
              name.textContent = "Choose recipient";
              avatar.textContent = "?";
              avatar.style.background = "var(--bg-surface-2)";
              avatar.style.color = "var(--text-muted)";
              avatar.style.border = "2px dashed var(--border-color)";
            }
          });
        }
      });
    </script>
  <% end %>
</div>
