<%# Activity feed — stub view (fully built in Branch 7) %>

<% content_for :title, "Activity — Splitwise" %>

<% content_for :top_bar do %>
  <%= render "shared/top_bar", title: "Activity" %>
<% end %>

<div class="animate-fade-in">
  <% if @notifications.empty? %>
    <div class="empty-state">
      <div class="empty-state__icon">🔔</div>
      <div class="empty-state__title">No activity yet</div>
      <div class="empty-state__text">Your notifications will appear here when group members add expenses.</div>
    </div>
  <% else %>
    <div class="card card--shadow">
      <% @notifications.each do |nr| %>
        <div class="list-item">
          <div class="avatar avatar--sm" style="background:var(--color-primary);">
            <%= nr.notification.actor.username.first.upcase %>
          </div>
          <div class="list-item__body">
            <div class="list-item__title"><%= nr.notification.title %></div>
            <div class="list-item__subtitle"><%= time_ago_in_words(nr.created_at) %> ago</div>
          </div>
          <% unless nr.read? %>
            <div style="width:8px;height:8px;background:var(--color-primary);border-radius:50%;flex-shrink:0;"></div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
