<% content_for :title, "Activity — Splitwise" %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<% content_for :top_bar do %>
  <header class="top-bar">
    <div class="top-bar__left"></div>
    <div class="top-bar__title">Recent Activity</div>
    <div class="top-bar__right"></div>
  </header>
<% end %>

<div class="animate-fade-in" data-turbo-cache="false">
  <h1 class="page-heading mb-md d-none-mobile">Recent Activity</h1>

  <div class="activity-search mb-md" id="activity-search-root">
    <%= form_with url: activity_path,
                  method: :get,
                  id: "activity-search-form",
                  class: "activity-search__form" do %>
      <div class="activity-search__field">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="activity-search__icon"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <%= text_field_tag :q, @query,
              id: "activity-search-input",
              placeholder: "Search expenses, notes, groups...",
              class: "activity-search__input",
              autocomplete: "off" %>
      </div>
      <button type="button"
              id="activity-search-clear"
              class="btn btn--outline btn--sm activity-search__clear"
              <%= "hidden" unless @query.present? %>>
        Clear
      </button>
    <% end %>

    <%= render "results" %>
  </div>
</div>
