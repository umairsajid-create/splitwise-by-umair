<%# Bottom navigation bar — 5 tabs like the real Splitwise app %>

<nav class="bottom-nav" aria-label="Main navigation">

  <%# 1. Home / Dashboard %>
  <%= link_to root_path,
        class: "bottom-nav__item #{current_page?(root_path) ? 'active' : ''}",
        "aria-label": "Home" do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    <span>Home</span>
  <% end %>

  <%# 2. Groups %>
  <%= link_to groups_path,
        class: "bottom-nav__item #{controller_name == 'groups' ? 'active' : ''}",
        "aria-label": "Groups" do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
    <span>Groups</span>
  <% end %>

  <%# 3. FAB — Add Expense (links to groups until expense form is built in Branch 5) %>
  <%= link_to groups_path,
        class: "bottom-nav__fab",
        "aria-label": "Add expense",
        "data-turbo-frame": "_top" do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
  <% end %>

  <%# 4. Activity / Notifications %>
  <%= link_to activity_path,
        class: "bottom-nav__item #{controller_name == 'activity' ? 'active' : ''}",
        "aria-label": "Activity",
        data: { turbo_cache: false } do %>
    <% unread_count = current_user.unread_notification_count %>
    <div style="position:relative; display:inline-flex;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <% if unread_count > 0 %>
        <span style="position:absolute;top:-4px;right:-4px;background:var(--color-negative);color:white;border-radius:999px;font-size:9px;font-weight:900;min-width:16px;height:16px;display:flex;align-items:center;justify-content:center;padding:0 3px;">
          <%= unread_count > 9 ? "9+" : unread_count %>
        </span>
      <% end %>
    </div>
    <span>Activity</span>
  <% end %>

  <%# 5. Account / Profile %>
  <%= link_to profile_path,
        class: "bottom-nav__item #{controller_name == 'profiles' ? 'active' : ''}",
        "aria-label": "Account" do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>
    </svg>
    <span>Account</span>
  <% end %>

</nav>
