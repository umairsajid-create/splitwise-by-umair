<%# locals: form, field, label:, hint: nil, preview: nil, accept: "image/*" %>
<div class="attachment-upload">
  <div class="attachment-upload__preview" id="<%= field %>-preview">
    <% if preview&.attached? %>
      <%= image_tag preview, class: "attachment-upload__image", alt: label %>
    <% end %>
  </div>

  <label class="attachment-upload__trigger">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    <span class="attachment-upload__label" id="<%= field %>-label"><%= label %></span>
    <%= form.file_field field,
          accept: accept,
          class: "attachment-upload__input",
          id: "#{field}_input",
          onchange: "previewAttachment(this, '#{field}-preview', '#{field}-label')" %>
  </label>

  <% if hint.present? %>
    <p class="attachment-upload__hint"><%= hint %></p>
  <% end %>
</div>

<script>
  if (typeof window.previewAttachment !== "function") {
    window.previewAttachment = function(input, previewId, labelId) {
      const preview = document.getElementById(previewId);
      const label = document.getElementById(labelId);
      if (!input.files || !input.files[0]) return;

      const file = input.files[0];
      label.textContent = file.name;

      if (file.type.startsWith("image/")) {
        const reader = new FileReader();
        reader.onload = function(e) {
          preview.innerHTML = '<img src="' + e.target.result + '" class="attachment-upload__image" alt="Preview">';
        };
        reader.readAsDataURL(file);
      } else {
        preview.innerHTML = '<div class="attachment-upload__file">' + file.name + '</div>';
      }
    };
  }
</script>
