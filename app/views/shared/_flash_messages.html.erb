<%# Flash message toasts — auto-dismiss via Stimulus %>
<%# Shown at top of every page, stacks if multiple messages %>

<div class="flash-container" aria-live="polite" id="global-flash-container" data-turbo-cache="false">
  <% flash.each do |type, message| %>
    <div class="flash flash--<%= type %>" role="alert">

      <%# Icon based on type %>
      <% if type.to_s.in?(%w[notice success]) %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      <% elsif type.to_s.in?(%w[alert error]) %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      <% else %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      <% end %>

      <span class="flash__message"><%= message %></span>

      <%# Close button %>
      <button class="flash__close"
              onclick="dismissFlashMessage(this.closest('.flash'))"
              aria-label="Dismiss">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>

<script>
  function dismissFlashMessage(el) {
    if (!el) return;
    el.style.transition = "opacity 0.35s cubic-bezier(0.47, 0, 0.745, 0.715), transform 0.35s cubic-bezier(0.47, 0, 0.745, 0.715)";
    el.style.opacity = "0";
    el.style.transform = "translateY(-60px)";
    setTimeout(() => el.remove(), 350);
  }

  // Auto-dismiss newly rendered flash messages after 3 seconds
  setTimeout(() => {
    const container = document.getElementById("global-flash-container");
    if (container) {
      container.querySelectorAll('.flash').forEach(el => dismissFlashMessage(el));
    }
  }, 3000);
</script>
