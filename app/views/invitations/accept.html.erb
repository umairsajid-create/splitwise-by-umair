<% content_for :title, "Join #{@invitation.group.name}" %>

<div class="container animate-fade-in" style="max-width: 480px; margin-top: 80px;">
  <div class="card card--shadow p-xl text-center">
    
    <div class="avatar avatar--xl avatar--teal mx-auto mb-md">
      <%= @invitation.group.name.first.upcase %>
    </div>

    <h1 class="page-heading mb-sm">You're invited!</h1>
    
    <p class="text-muted mb-lg" style="font-size: var(--font-size-md);">
      <strong><%= @invitation.invited_by.username %></strong> invited you to join the group 
      <strong style="color: var(--text-primary);"><%= @invitation.group.name %></strong> on Splitwise.
    </p>

    <%= form_with url: confirm_invitation_path(token: @invitation.token), method: :post, local: true do |f| %>
      <%= f.submit "Accept Invitation", class: "btn btn--primary btn--block btn--lg mb-sm" %>
    <% end %>

    <%= link_to "Cancel", root_path, class: "btn btn--outline btn--block" %>
    
  </div>
</div>
