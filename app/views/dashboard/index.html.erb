<%# Dashboard - Main landing page %>
<% content_for :title, "Dashboard — Splitwise" %>

<% content_for :top_bar do %>
  <%= render "shared/top_bar", title: "Dashboard" %>
<% end %>

<div class="animate-fade-in">

  <%# 1. Total Balance Summary Card %>
  <div class="balance-card">
    <div class="balance-card__label">Total Balance</div>
    <div class="balance-card__amount">
      <% if @total_balance > 0 %>
        +<%= number_to_currency(@total_balance, unit: current_user.default_currency + " ") %>
      <% elsif @total_balance < 0 %>
        -<%= number_to_currency(@total_balance.abs, unit: current_user.default_currency + " ") %>
      <% else %>
        <%= number_to_currency(0, unit: current_user.default_currency + " ") %>
      <% end %>
    </div>

    <div class="balance-card__row">
      <div class="balance-card__sub">
        <div class="balance-card__sub-label">You owe</div>
        <div class="balance-card__sub-amount" style="color: #FFC0B3;">
          <%= number_to_currency(@you_owe, unit: current_user.default_currency + " ") %>
        </div>
      </div>
      <div style="width:1px; background:rgba(255,255,255,0.2);"></div>
      <div class="balance-card__sub text-right">
        <div class="balance-card__sub-label">You are owed</div>
        <div class="balance-card__sub-amount" style="color: #E8F8F4;">
          <%= number_to_currency(@you_are_owed, unit: current_user.default_currency + " ") %>
        </div>
      </div>
    </div>
  </div>

  <%# Action Buttons %>
  <div class="d-flex gap-sm mb-md">
    <%= link_to groups_path, class: "btn btn--primary flex-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Add Expense
    <% end %>
    
    <%= link_to "#", class: "btn btn--outline flex-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
        <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
      </svg>
      Settle Up
    <% end %>
  </div>

  <%# 2. Your Groups List %>
  <div class="section-header mt-lg">
    <h2 class="section-title">Your Groups</h2>
    <%= link_to "View all", groups_path, class: "section-action" %>
  </div>

  <% if @groups.any? %>
    <div class="card card--shadow mb-md">
      <% @groups.take(3).each do |group| %>
        <%= link_to group_path(group), class: "list-item" do %>
          <div class="avatar avatar--sm avatar--teal">
            <%= group.name.first.upcase %>
          </div>
          <div class="list-item__body">
            <div class="list-item__title"><%= group.name %></div>
            <div class="list-item__subtitle">
              <span class="badge badge--<%= group.group_type %>">
                <%= group.group_type.capitalize %>
              </span>
            </div>
          </div>
          <div class="list-item__meta">
            <div class="list-item__amount amount--neutral">settled up</div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card card--shadow mb-md text-center" style="padding: var(--space-lg);">
      <div class="text-muted mb-sm">You aren't in any groups yet.</div>
      <%= link_to "Create a Group", new_group_path, class: "btn btn--outline btn--sm" %>
    </div>
  <% end %>

  <%# 3. Recent Activity (Expenses) %>
  <div class="section-header mt-lg">
    <h2 class="section-title">Recent Expenses</h2>
  </div>

  <% if @recent_expenses.any? %>
    <div class="card card--shadow">
      <% @recent_expenses.each do |expense| %>
        <div class="list-item">
          <div class="category-icon category-icon--general">🧾</div>
          <div class="list-item__body">
            <div class="list-item__title"><%= expense.title %></div>
            <div class="list-item__subtitle">
              <span class="fw-bold"><%= expense.created_by.username %></span> paid
              in <%= expense.group.name %>
            </div>
          </div>
          <div class="list-item__meta">
            <div class="list-item__amount amount--neutral">
              <%= number_to_currency(expense.total_amount_cents / 100.0, unit: current_user.default_currency + " ") %>
            </div>
            <div class="list-item__date"><%= expense.expense_date.strftime("%b %d") %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card card--shadow text-center" style="padding: var(--space-lg);">
      <div class="text-muted">No recent expenses.</div>
    </div>
  <% end %>

  <div class="spacer--lg"></div>
</div>
